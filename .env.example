# Copie este arquivo para .env.local e preencha os valores

# YouTube — ID do vídeo exibido na home (ex: 7VCgxcRYR1M)
NEXT_PUBLIC_YOUTUBE_VIDEO_ID=

# GNews API — notícias de futebol na home
# Obtenha sua chave gratuitamente em https://gnews.io
# Sem esta variável, o slot de notícias mostra o banner do CTA (slot 0)
GNEWS_API_KEY=
